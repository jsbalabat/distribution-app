# Firebase Web Configuration
# Copy this file to .env and fill in your actual Firebase credentials
# DO NOT commit .env file to source control

# Web Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_auth_domain.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_storage_bucket.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id

# Environment
ENVIRONMENT=development
# Options: development, staging, production
